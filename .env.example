# =============================================================================
# Blackboex — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values for your environment.
# .env is gitignored; never commit real secrets.

# -----------------------------------------------------------------------------
# Required — must be set in production
# -----------------------------------------------------------------------------

# PostgreSQL connection string
DATABASE_URL=ecto://user:pass@host/blackboex_prod

# Phoenix secret key base — generate with: mix phx.gen.secret
SECRET_KEY_BASE=

# Public hostname (no scheme, no trailing slash)
PHX_HOST=your-domain.com

# Encryption key for Cloak — generate with: mix cloak.gen.key AES.GCM
CLOAK_KEY=

# Transactional email API key (Resend / Mailgun / etc.)
MAILER_API_KEY=

# -----------------------------------------------------------------------------
# Optional — defaults shown
# -----------------------------------------------------------------------------

# HTTP port
PORT=4000

# Ecto connection pool size
POOL_SIZE=10

# Base URL for the Playground sandbox (defaults to PHX_HOST)
PLAYGROUND_BASE_URL=https://your-domain.com

# OpenTelemetry OTLP endpoint
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# DNS cluster query for distributed deployments (Fly.io, Kubernetes)
# DNS_CLUSTER_QUERY=myapp.internal

# Use IPv6 for Ecto connections (set to "true" for Fly.io)
# ECTO_IPV6=false

# Start Phoenix server on boot (set to "true" in Docker / releases)
# PHX_SERVER=true
