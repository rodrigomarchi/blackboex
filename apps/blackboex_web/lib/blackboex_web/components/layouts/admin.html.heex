<Backpex.HTML.Layout.app_shell live_resource={@live_resource}>
  <:topbar>
    <a href="/" class="text-lg font-semibold">BlackBoex Admin</a>
  </:topbar>
  <:sidebar>
    <Backpex.HTML.Layout.sidebar_item current_url={@current_url} navigate="/admin">
      <Backpex.HTML.CoreComponents.icon name="hero-chart-bar" class="size-5" /> Dashboard
    </Backpex.HTML.Layout.sidebar_item>

    <Backpex.HTML.Layout.sidebar_section id="core">
      <:label>Core</:label>
      <Backpex.HTML.Layout.sidebar_item current_url={@current_url} navigate="/admin/users">
        <Backpex.HTML.CoreComponents.icon name="hero-users" class="size-5" /> Users
      </Backpex.HTML.Layout.sidebar_item>
      <Backpex.HTML.Layout.sidebar_item current_url={@current_url} navigate="/admin/user-tokens">
        <Backpex.HTML.CoreComponents.icon name="hero-finger-print" class="size-5" /> User Tokens
      </Backpex.HTML.Layout.sidebar_item>
      <Backpex.HTML.Layout.sidebar_item current_url={@current_url} navigate="/admin/organizations">
        <Backpex.HTML.CoreComponents.icon name="hero-building-office" class="size-5" />
        Organizations
      </Backpex.HTML.Layout.sidebar_item>
      <Backpex.HTML.Layout.sidebar_item current_url={@current_url} navigate="/admin/memberships">
        <Backpex.HTML.CoreComponents.icon name="hero-user-group" class="size-5" /> Memberships
      </Backpex.HTML.Layout.sidebar_item>
      <Backpex.HTML.Layout.sidebar_item current_url={@current_url} navigate="/admin/apis">
        <Backpex.HTML.CoreComponents.icon name="hero-bolt" class="size-5" /> APIs
      </Backpex.HTML.Layout.sidebar_item>
      <Backpex.HTML.Layout.sidebar_item current_url={@current_url} navigate="/admin/subscriptions">
        <Backpex.HTML.CoreComponents.icon name="hero-credit-card" class="size-5" /> Subscriptions
      </Backpex.HTML.Layout.sidebar_item>
    </Backpex.HTML.Layout.sidebar_section>

    <Backpex.HTML.Layout.sidebar_section id="api-data">
      <:label>API Data</:label>
      <Backpex.HTML.Layout.sidebar_item current_url={@current_url} navigate="/admin/api-keys">
        <Backpex.HTML.CoreComponents.icon name="hero-key" class="size-5" /> API Keys
      </Backpex.HTML.Layout.sidebar_item>
      <Backpex.HTML.Layout.sidebar_item current_url={@current_url} navigate="/admin/api-versions">
        <Backpex.HTML.CoreComponents.icon name="hero-code-bracket" class="size-5" /> API Versions
      </Backpex.HTML.Layout.sidebar_item>
      <Backpex.HTML.Layout.sidebar_item
        current_url={@current_url}
        navigate="/admin/api-conversations"
      >
        <Backpex.HTML.CoreComponents.icon name="hero-chat-bubble-left-right" class="size-5" />
        Conversations
      </Backpex.HTML.Layout.sidebar_item>
      <Backpex.HTML.Layout.sidebar_item
        current_url={@current_url}
        navigate="/admin/data-store-entries"
      >
        <Backpex.HTML.CoreComponents.icon name="hero-circle-stack" class="size-5" /> Data Store
      </Backpex.HTML.Layout.sidebar_item>
      <Backpex.HTML.Layout.sidebar_item
        current_url={@current_url}
        navigate="/admin/invocation-logs"
      >
        <Backpex.HTML.CoreComponents.icon name="hero-arrow-path" class="size-5" /> Invocation Logs
      </Backpex.HTML.Layout.sidebar_item>
      <Backpex.HTML.Layout.sidebar_item
        current_url={@current_url}
        navigate="/admin/metric-rollups"
      >
        <Backpex.HTML.CoreComponents.icon name="hero-chart-bar" class="size-5" /> Metric Rollups
      </Backpex.HTML.Layout.sidebar_item>
    </Backpex.HTML.Layout.sidebar_section>

    <Backpex.HTML.Layout.sidebar_section id="billing">
      <:label>Billing</:label>
      <Backpex.HTML.Layout.sidebar_item current_url={@current_url} navigate="/admin/daily-usage">
        <Backpex.HTML.CoreComponents.icon name="hero-calendar-days" class="size-5" /> Daily Usage
      </Backpex.HTML.Layout.sidebar_item>
      <Backpex.HTML.Layout.sidebar_item current_url={@current_url} navigate="/admin/usage-events">
        <Backpex.HTML.CoreComponents.icon name="hero-signal" class="size-5" /> Usage Events
      </Backpex.HTML.Layout.sidebar_item>
      <Backpex.HTML.Layout.sidebar_item
        current_url={@current_url}
        navigate="/admin/processed-events"
      >
        <Backpex.HTML.CoreComponents.icon name="hero-check-badge" class="size-5" />
        Processed Events
      </Backpex.HTML.Layout.sidebar_item>
    </Backpex.HTML.Layout.sidebar_section>

    <Backpex.HTML.Layout.sidebar_section id="testing">
      <:label>Testing</:label>
      <Backpex.HTML.Layout.sidebar_item current_url={@current_url} navigate="/admin/test-requests">
        <Backpex.HTML.CoreComponents.icon name="hero-beaker" class="size-5" /> Test Requests
      </Backpex.HTML.Layout.sidebar_item>
      <Backpex.HTML.Layout.sidebar_item current_url={@current_url} navigate="/admin/test-suites">
        <Backpex.HTML.CoreComponents.icon name="hero-clipboard-document-check" class="size-5" />
        Test Suites
      </Backpex.HTML.Layout.sidebar_item>
    </Backpex.HTML.Layout.sidebar_section>

    <Backpex.HTML.Layout.sidebar_section id="llm-audit">
      <:label>LLM & Audit</:label>
      <Backpex.HTML.Layout.sidebar_item current_url={@current_url} navigate="/admin/llm-usage">
        <Backpex.HTML.CoreComponents.icon name="hero-cpu-chip" class="size-5" /> LLM Usage
      </Backpex.HTML.Layout.sidebar_item>
      <Backpex.HTML.Layout.sidebar_item current_url={@current_url} navigate="/admin/audit-logs">
        <Backpex.HTML.CoreComponents.icon name="hero-document-text" class="size-5" /> Audit Logs
      </Backpex.HTML.Layout.sidebar_item>
      <Backpex.HTML.Layout.sidebar_item current_url={@current_url} navigate="/admin/versions">
        <Backpex.HTML.CoreComponents.icon name="hero-clock" class="size-5" /> Versions
      </Backpex.HTML.Layout.sidebar_item>
    </Backpex.HTML.Layout.sidebar_section>
  </:sidebar>
  <Backpex.HTML.Layout.flash_messages flash={@flash} />
  <%= if assigns[:inner_content] != nil and assigns[:inner_content] != [] do %>
    {render_slot(@inner_content)}
  <% else %>
    {render_slot(@inner_block)}
  <% end %>
</Backpex.HTML.Layout.app_shell>
