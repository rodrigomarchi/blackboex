{
  "annotations": { "list": [] },
  "editable": true,
  "panels": [
    {
      "title": "LLM Requests by Provider",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(blackboex_web_prom_ex_llm_requests_total[5m])",
          "legendFormat": "{{provider}}/{{model}}",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ]
    },
    {
      "title": "LLM Latency P95",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (provider, model, le) (rate(blackboex_web_prom_ex_llm_request_duration_milliseconds_bucket[5m])))",
          "legendFormat": "{{provider}}/{{model}}",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" } }
    },
    {
      "title": "Total Tokens Consumed",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum by (provider, model) (blackboex_web_prom_ex_llm_tokens_total)",
          "legendFormat": "{{provider}}/{{model}}",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ]
    },
    {
      "title": "LLM Request Count (24h)",
      "type": "stat",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "sum(increase(blackboex_web_prom_ex_llm_requests_total[24h]))",
          "legendFormat": "Total",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["blackboex", "llm"],
  "time": { "from": "now-1h", "to": "now" },
  "title": "LLM",
  "uid": "blackboex-llm"
}
