#!/bin/sh

# Sets and samples the release environment.
# This runs every time the release boots (start, remote, eval, rpc).

# Start the Phoenix server when PHX_SERVER is set
if [ "$PHX_SERVER" = "true" ]; then
  export RELEASE_DISTRIBUTION=none
  export ERL_FLAGS="+sbwt very_short +sbwtdcpu very_short +sbwtdio very_short"
fi
